SILICONFLOW_API_KEY=sk-vjutyyqmciqxvzsywuawcuazmenjrdxdwrvfnofjaotcywgl
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-R1


AGUNT_HOST=127.0.0.1
AGUNT_PORT=8000
AGUNT_RELOAD=0
AGUNT_WEB_API_KEY=

# agent execution switch (1=enabled, 0=disabled)
AGUNT_AGENT_EXEC_ENABLED=1

# --- Health Scoring (Agent Task Steps Summary) ---
# p95 latency threshold in ms; only latency above this threshold starts to incur penalties
AGUNT_HEALTH_P95_THRESHOLD_MS=1000
# penalty points per +100ms beyond p95 threshold
AGUNT_HEALTH_PENALTY_PER_100MS=1
# max penalty cap
AGUNT_HEALTH_PENALTY_CAP=40
# health level boundaries
AGUNT_HEALTH_GREEN_MIN_SCORE=90
AGUNT_HEALTH_YELLOW_MIN_SCORE=70
AGUNT_HEALTH_YELLOW_MAX_FAILURE_RATE=20.0
# neutral score when no step data is available
AGUNT_HEALTH_EMPTY_SCORE=50

# optional salt for summary_id signature (recommended per environment)
AGUNT_SUMMARY_ID_SALT=